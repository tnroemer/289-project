d-3454f0a4069e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Number of images: 2594\n","Number of masks: 2594\n"]}]},{"cell_type":"code","source":["class ISICSegmentationDataset(Dataset):\n","    def __init__(self, image_dir, mask_dir, image_size=256):\n","        self.image_dir = image_dir\n","        self.mask_dir = mask_dir\n","        self.image_size = image_size\n","\n","        self.image_files = sorted([\n","            f for f in os.listdir(image_dir)\n","            if f.endswith(\".jpg\")\n","        ])\n","\n","        self.image_transform = T.Compose([\n","            T.Resize((image_size, image_size)),\n","            T.ToTensor(),\n","        ])\n","\n","        self.mask_transform = T.Compose([\n","            T.Resize((image_size, image_size), interpolation=T.InterpolationMode.NEAREST),\n","            T.ToTensor(),\n","        ])\n","\n","    def __len__(self):\n","        return len(self.image_files)\n","\n","    def __getitem__(self, idx):\n","        image_name = self.image_files[idx]\n","        base_name = image_name.replace(\".jpg\", \"\")\n","        mask_name = base_name + \"_segmentation.png\"\n","\n","        image_path = os.path.join(self.image_dir, image_name)\n","        mask_path = os.path.join(self.mask_dir, mask_name)\n","\n","        image = Image.open(image_path).convert(\"RGB\")\n","        mask = Image.open(mask_path).convert(\"L\")\n","\n","        image = self.image_transform(image)\n","        mask = self.mask_transform(mask)\n","\n","        mask = (mask > 0.5).float()\n","\n","        return image, mask"],"metadata":{"id":"WGb38X5Mkh3N"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["dataset = ISICSegmentationDataset(image_dir, mask_dir, image_size=256)\n","\n","train_size = int(0.8 * len(dataset))\n","val_size = len(dataset) - train_size\n","\n","train_dataset, val_dataset = random_split(\n","    dataset,\n","    [train_size, val_size],\n","    generator=torch.Generator().manual_seed(42)\n",")\n","\n","train_loader = DataLoader(\n","    train_dataset,\n","    batch_size=16,\n","    shuffle=True,\n","    num_workers=2,\n","    pin_memory=True\n",")\n","\n","val_loader = DataLoader(\n","    val_dataset,\n","    batch_size=16,\n","    shuffle=False,\n","    num_workers=2,\n","    pin_memory=True\n",")\n","\n","print(\"Train size:\", len(train_dataset))\n","print(\"Validation size:\", len(val_dataset))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"bkuLfBkTkkdR","executionInfo":{"status":"ok","timestamp":1777337524720,"user_tz":420,"elapsed":43,"user":{"displayName":"Zichuan Li","userId":"06603988428494756370"}},"outputId":"cc17aae1-2e09-41b9-b98a-14231a095d68"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Train size: 2075\n","Validation size: 519\n"]}]},{"cell_type":"code","source":["class DoubleConv(nn.Module):\n","    def __init__(self, in_channels, out_channels):\n","        super().__init__()\n","\n","        self.net = nn.Sequential(\n","            nn.Conv2d(in_channels, out_channels, kernel_size=3, padding=1),\n","            nn.BatchNorm2d(out_channels),\n","            nn.ReLU(inplace=True),\n","\n","            nn.Conv2d(out_channels, out_channels, kernel_size=3, padding=1),\n","            nn.BatchNorm2d(out_channels),\n","            nn.ReLU(inplace=True),\n","        )\n","\n","    def forward(self, x):\n","        return self.net(x)\n","\n","\n","class SimpleUNet(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","\n","        self.down1 = DoubleConv(3, 32)\n","        self.pool1 = nn.MaxPool2d(2)\n","\n","        self.down2 = DoubleConv(32, 64)\n","        self.pool2 = nn.MaxPool2d(2)\n","\n","        self.down3 = DoubleConv(64, 128)\n","        self.pool3 = nn.MaxPool2d(2)\n","\n","        self.bottleneck = DoubleConv(128, 256)\n","\n","        self.up3 = nn.ConvTranspose2d(256, 128, kernel_size=2, stride=2)\n","        self.conv3 = DoubleConv(256, 128)\n","\n","        self.up2 = nn.ConvTranspose2d(128, 64, kernel_size=2, stride=2)\n","        self.conv2 = DoubleConv(128, 64)\n","\n","        self.up1 = nn.ConvTranspose2d(64, 32, kernel_size=2, stride=2)\n","        self.conv1 = DoubleConv(64, 32)\n","\n","        self.out = nn.Conv2d(32, 1, kernel_size=1)\n","\n","    def forward(self, x):\n","        c1 = self.down1(x)\n","        p1 = self.pool1(c1)\n","\n","        c2 = self.down2(p1)\n","        p2 = self.pool2(c2)\n","\n","        c3 = self.down3(p2)\n","        p3 = self.pool3(c3)\n","\n","        b = self.bottleneck(p3)\n","\n","        u3 = self.up3(b)\n","        x = torch.cat([u3, c3], dim=1)\n","        x = self.conv3(x)\n","\n","        u2 = self.up2(x)\n","        x = torch.cat([u2, c2], dim=1)\n","        x = self.conv2(x)\n","\n","        u1 = self.up1(x)\n","        x = torch.cat([u1, c1], dim=1)\n","        x = self.conv1(x)\n","\n","        return self.out(x)"],"metadata":{"id":"oNCEoCEtkqJ1"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def dice_loss_from_logits(logits, masks, eps=1e-6):\n","    probs = torch.sigmoid(logits)\n","\n","    probs = probs.view(probs.size(0), -1)\n","    masks = masks.view(masks.size(0), -1)\n","\n","    intersection = (probs * masks).sum(dim=1)\n","    total = probs.sum(dim=1) + masks.sum(dim=1)\n","\n","    dice = (2 * intersection + eps) / (total + eps)\n","    return 1 - dice.mean()\n","\n","\n","def dice_score_from_logits(logits, masks, threshold=0.5, eps=1e-6):\n","    probs = torch.sigmoid(logits)\n","    preds = (probs > threshold).float()\n","\n","    preds = preds.view(preds.size(0), -1)\n","    masks = masks.view(masks.size(0), -1)\n","\n","    intersection = (preds * masks).sum(dim=1)\n","    total = preds.sum(dim=1) + masks.sum(dim=1)\n","\n","    dice = (2 * intersection + eps) / (total + eps)\n","    return dice.mean()"],"metadata":{"id":"o-k79TxCkr-0"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","print(\"Using device:\", device)\n","\n","model = SimpleUNet().to(device)\n","\n","bce_criterion = nn.BCEWithLogitsLoss()\n","optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0hEjedKkkwnT","executionInfo":{"status":"ok","timestamp":1777337573170,"user_tz":420,"elapsed":329,"user":{"displayName":"Zichuan Li","userId":"06603988428494756370"}},"outputId":"a5721908-238b-43fd-97c5-e641a9f5a2bb"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Using device: cuda\n"]}]},{"cell_type":"code","source":["num_epochs = 10\n","\n","train_losses = []\n","val_losses = []\n","val_dices = []\n","\n","for epoch in range(num_epochs):\n","    # ---- training ----\n","    model.train()\n","    train_loss = 0.0\n","\n","    for images, masks in train_loader:\n","        images = images.to(device)\n","        masks = masks.to(device)\n","\n","        optimizer.zero_grad()\n","\n","        logits = model(images)\n","\n","        bce_loss = bce_criterion(logits, masks)\n","        dice_loss = dice_loss_from_logits(logits, masks)\n","        loss = bce_loss + dice_loss\n","\n","        loss.backward()\n","        optimizer.step()\n","\n","        train_loss += loss.item() * images.size(0)\n","\n","    train_loss /= len(train_loader.dataset)\n","\n","    # ---- validation ----\n","    model.eval()\n","    val_loss = 0.0\n","    val_dice = 0.0\n","\n","    with torch.no_grad():\n","        for images, masks in val_loader:\n","            images = images.to(device)\n","            masks = masks.to(device)\n","\n","            logits = model(images)\n","\n","            bce_loss = bce_criterion(logits, masks)\n","            dice_loss = dice_loss_from_logits(logits, masks)\n","            loss = bce_loss + dice_loss\n","\n","            dice = dice_score_from_logits(logits, masks)\n","\n","            val_loss += loss.item() * images.size(0)\n","            val_dice += dice.item() * images.size(0)\n","\n","    val_loss /= len(val_loader.dataset)\n","    val_dice /= len(val_loader.dataset)\n","\n","    train_losses.append(train_loss)\n","    val_losses.append(val_loss)\n","    val_dices.append(val_dice)\n","\n","    print(\n","        f\"Epoch {epoch+1}/{num_epochs} | \"\n","        f\"Train Loss: {train_loss:.4f} | \"\n","        f\"Val Loss: {val_loss:.4f} | \"\n","        f\"Val Dice: {val_dice:.4f}\"\n","    )"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ReFYoue6k0Dn","executionInfo":{"status":"ok","timestamp":1777341933928,"user_tz":420,"elapsed":435864,"user":{"displayName":"Zichuan Li","userId":"06603988428494756370"}},"outputId":"7c554074-9460-45ed-fd12-544b93dab717"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Epoch 1/10 | Train Loss: 0.9500 | Val Loss: 0.8627 | Val Dice: 0.6666\n","Epoch 2/10 | Train Loss: 0.7111 | Val Loss: 0.8424 | Val Dice: 0.6360\n","Epoch 3/10 | Train Loss: 0.6150 | Val Loss: 0.5944 | Val Dice: 0.7472\n","Epoch 4/10 | Train Loss: 0.5695 | Val Loss: 0.6469 | Val Dice: 0.7449\n","Epoch 5/10 | Train Loss: 0.5275 | Val Loss: 0.5557 | Val Dice: 0.7607\n","Epoch 6/10 | Train Loss: 0.5108 | Val Loss: 0.5642 | Val Dice: 0.7629\n","Epoch 7/10 | Train Loss: 0.5140 | Val Loss: 0.5745 | Val Dice: 0.7642\n","Epoch 8/10 | Train Loss: 0.4812 | Val Loss: 0.5948 | Val Dice: 0.7493\n","Epoch 9/10 | Train Loss: 0.4709 | Val Loss: 0.4947 | Val Dice: 0.7879\n","Epoch 10/10 | Train Loss: 0.4483 | Val Loss: 0.5215 | Val Dice: 0.7796\n"]}]},{"cell_type":"code","source":["# save model\n","model_save_path = \"/content/drive/MyDrive/CS289A/project/segmentation_unet_v2.pth\"\n","torch.save(model.state_dict(), model_save_path)\n","\n","print(\"Saved model to:\", model_save_path)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7_7p11MI1kkJ","executionInfo":{"status":"ok","timesta