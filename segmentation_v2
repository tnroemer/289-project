ost-process\n","            for i in range(preds_np.shape[0]):\n","                pred_mask = preds_np[i, 0]\n","                true_mask = masks_np[i, 0]\n","\n","                cleaned_pred = clean_binary_mask(pred_mask)\n","                dice = dice_score_binary_numpy(cleaned_pred, true_mask)\n","\n","                dices.append(dice)\n","\n","    mean_dice = np.mean(dices)\n","    threshold_results.append((threshold, mean_dice))\n","\n","    print(f\"Threshold {threshold:.1f} | Mean validation Dice after post-processing: {mean_dice:.4f}\")\n","\n","best_threshold, best_dice = max(threshold_results, key=lambda x: x[1])\n","\n","print()\n","print(\"Best threshold:\", best_threshold)\n","print(\"Best validation Dice:\", best_dice)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"AmqAFsG0IND3","executionInfo":{"status":"ok","timestamp":1777347393433,"user_tz":420,"elapsed":509565,"user":{"displayName":"Zichuan Li","userId":"06603988428494756370"}},"outputId":"f888b07b-96df-4523-cf42-f4e7a8ed003d"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Threshold 0.2 | Mean validation Dice after post-processing: 0.7655\n","Threshold 0.3 | Mean validation Dice after post-processing: 0.7766\n","Threshold 0.4 | Mean validation Dice after post-processing: 0.7843\n","Threshold 0.5 | Mean validation Dice after post-processing: 0.7860\n","Threshold 0.6 | Mean validation Dice after post-processing: 0.7837\n","Threshold 0.7 | Mean validation Dice after post-processing: 0.7762\n","\n","Best threshold: 0.5\n","Best validation Dice: 0.7859711\n"]}]},{"cell_type":"code","source":["model.eval()\n","\n","images, masks = next(iter(val_loader))\n","images_gpu = images.to(device)\n","\n","with torch.no_grad():\n","    logits = model(images_gpu)\n","    probs = torch.sigmoid(logits)\n","    raw_preds = (probs > best_threshold).float()\n","\n","raw_preds_np = raw_preds.cpu().numpy()\n","\n","cleaned_preds = []\n","\n","for i in range(ra